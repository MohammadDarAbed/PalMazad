      "ProductModel": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "categoryId": {
            "$ref": "#/components/schemas/Category"
          },
          "productQR": {
            "type": "string",
            "nullable": true
          }
